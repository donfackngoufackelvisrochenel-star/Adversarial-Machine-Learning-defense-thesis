{
  "build": {
    "dockerfile": "deployment/Dockerfile"
  },
  "deploy": {
    "startCommand": "streamlit run src/dashboard/streamlit_app.py --server.port 8080 --server.address 0.0.0.0 --server.enableCORS=false --server.enableXsrfProtection=false --server.maxUploadSize=10",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
